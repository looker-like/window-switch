<Window x:Class="WindowSwitch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:WindowSwitch.Controls"
        Title="WindowSwitch"
        SizeToContent="Manual"
        Width="520"
        Height="260"
        MinWidth="230"
        MinHeight="160"
        MaxWidth="900"
        MaxHeight="720"
        Opacity="{Binding WindowOpacity}"
        ShowInTaskbar="False"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        ShowActivated="False"
        Background="Transparent">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="HeaderIconButtonStyle" TargetType="{x:Type ButtonBase}">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#556070" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ButtonBase}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#EEF2F7" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#DDE5F0" />
                            </Trigger>
                            <Trigger Property="ToggleButton.IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#2563EB" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#1D4ED8" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootChrome"
            Margin="0"
            Padding="10"
            Background="#FAFFFFFF"
            BorderBrush="#31405060"
            BorderThickness="1"
            CornerRadius="10"
            MouseLeftButtonDown="RootChrome_MouseLeftButtonDown"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="3"
                              Direction="270"
                              Opacity="0.22"
                              Color="#1F2937" />
        </Border.Effect>
        <DockPanel LastChildFill="True">
            <Grid x:Name="HeaderBar"
                  DockPanel.Dock="Top"
                  Margin="2,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Width="18"
                        Height="18"
                        CornerRadius="5"
                        Background="Transparent"
                        VerticalAlignment="Center"
                        SnapsToDevicePixels="True">
                    <Image x:Name="HeaderAppIcon"
                           Width="18"
                           Height="18"
                           Stretch="Uniform"
                           SnapsToDevicePixels="True" />
                </Border>
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="WindowSwitch"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#2F3A4A" />
                    <TextBlock Text="{Binding CurrentDesktopName, StringFormat=' / {0}'}"
                               Margin="5,1,0,0"
                               FontSize="11"
                               Foreground="#64748B" />
                </StackPanel>
                <StackPanel Grid.Column="3"
                            Orientation="Horizontal">
                    <ToggleButton IsChecked="{Binding IsFloatingTopmost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource HeaderIconButtonStyle}"
                                  ToolTip="置顶悬浮">
                        <TextBlock Text="&#xE718;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="13" />
                    </ToggleButton>
                    <Button Style="{StaticResource HeaderIconButtonStyle}"
                            ToolTip="设置"
                            Click="SettingsButton_Click">
                        <TextBlock Text="&#xE713;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="13" />
                    </Button>
                    <Button Style="{StaticResource HeaderIconButtonStyle}"
                            ToolTip="隐藏到后台"
                            Click="CloseButton_Click">
                        <TextBlock Text="&#xE711;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12" />
                    </Button>
                </StackPanel>
            </Grid>

            <TextBlock x:Name="StatusBlock"
                       DockPanel.Dock="Bottom"
                       Text="{Binding StatusMessage}"
                       Visibility="{Binding HasStatus, Converter={StaticResource BooleanToVisibilityConverter}}"
                       Margin="2,6,2,0"
                       MaxWidth="460"
                       FontSize="12"
                       Foreground="#B42318"
                       TextWrapping="Wrap" />

            <controls:DesktopOverlayView x:Name="DesktopOverlay"
                                         Desktops="{Binding Desktops}"
                                         Actions="{Binding VirtualDesktopActions}"
                                         ColumnsPerRow="{Binding ColumnsPerRow}"
                                         EnableColoredDesktopLabels="{Binding EnableColoredDesktopLabels}"
                                         DesktopInvoked="DesktopOverlay_DesktopInvoked"
                                         ActionInvoked="DesktopOverlay_ActionInvoked" />
        </DockPanel>
    </Border>
</Window>
