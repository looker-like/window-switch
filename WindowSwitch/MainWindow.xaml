<Window x:Class="WindowSwitch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:WindowSwitch.ViewModels"
        Title="WindowSwitch"
        Icon="Assets/AppIcon.ico"
        SizeToContent="Manual"
        Width="520"
        Height="420"
        MinWidth="230"
        MinHeight="260"
        MaxWidth="900"
        MaxHeight="900"
        Opacity="{Binding WindowOpacity}"
        ShowInTaskbar="False"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        ShowActivated="False"
        Background="Transparent">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="CloseButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#556070" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#EEF2F7" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#DDE5F0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderIconButtonStyle" TargetType="{x:Type ButtonBase}">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#556070" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ButtonBase}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#EEF2F7" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#DDE5F0" />
                            </Trigger>
                            <Trigger Property="ToggleButton.IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#2563EB" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#1D4ED8" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#3A4658" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="DesktopButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="MinHeight" Value="46" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="#F1F5F9" />
            <Setter Property="BorderBrush" Value="#D8E0EA" />
            <Setter Property="Foreground" Value="#1F2937" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#E6EDF6" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#D6E2F1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                    <Setter Property="Background" Value="#2563EB" />
                    <Setter Property="BorderBrush" Value="#1D4ED8" />
                    <Setter Property="Foreground" Value="White" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsGestureSelected}" Value="True">
                    <Setter Property="Background" Value="#F59E0B" />
                    <Setter Property="BorderBrush" Value="#D97706" />
                    <Setter Property="Foreground" Value="White" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="VirtualDesktopActionButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#D8E0EA" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#E6EDF6" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#D6E2F1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsGestureSelected}" Value="True">
                    <Setter Property="Background" Value="#F59E0B" />
                    <Setter Property="BorderBrush" Value="#D97706" />
                    <Setter Property="Foreground" Value="White" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="RootChrome"
            Margin="0"
            Padding="10"
            Background="#FAFFFFFF"
            BorderBrush="#31405060"
            BorderThickness="1"
            CornerRadius="8"
            MouseLeftButtonDown="RootChrome_MouseLeftButtonDown"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="3"
                              Direction="270"
                              Opacity="0.22"
                              Color="#1F2937" />
        </Border.Effect>
        <StackPanel>
            <Grid Margin="2,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Width="18"
                        Height="18"
                        CornerRadius="5"
                        Background="#2563EB"
                        VerticalAlignment="Center"
                        SnapsToDevicePixels="True">
                    <TextBlock Text="W"
                               Foreground="White"
                               FontSize="11"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="WindowSwitch"
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#2F3A4A" />
                <StackPanel Grid.Column="3"
                            Orientation="Horizontal">
                    <ToggleButton IsChecked="{Binding IsFloatingTopmost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource HeaderIconButtonStyle}"
                                  ToolTip="置顶悬浮">
                        <TextBlock Text="&#xE718;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="13" />
                    </ToggleButton>
                    <ToggleButton x:Name="SettingsButton"
                                  Style="{StaticResource HeaderIconButtonStyle}"
                                  ToolTip="设置"
                                  Click="SettingsButton_Click">
                        <TextBlock Text="&#xE713;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="13" />
                    </ToggleButton>
                    <Button Style="{StaticResource HeaderIconButtonStyle}"
                            ToolTip="隐藏到后台"
                            Click="CloseButton_Click">
                        <TextBlock Text="&#xE711;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12" />
                    </Button>
                </StackPanel>

            </Grid>

            <Border x:Name="SettingsPanel"
                    Visibility="Collapsed"
                    Margin="2,0,2,10"
                    Padding="12"
                    Background="#FFFFFFFF"
                    BorderBrush="#D5DEE8"
                    BorderThickness="1"
                    CornerRadius="8"
                    SnapsToDevicePixels="True">
                <StackPanel>
                    <TextBlock Text="设置"
                               Margin="0,0,0,10"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#1F2937" />

                    <CheckBox Content="启动后隐藏到后台"
                              IsChecked="{Binding StartHidden, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Margin="0,0,0,8"
                              Foreground="#2F3A4A" />

                    <CheckBox Content="切换后自动隐藏"
                              IsChecked="{Binding AutoHideAfterSwitch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Margin="0,0,0,8"
                              Foreground="#2F3A4A" />

                    <CheckBox Content="启用唤起快捷键"
                              IsChecked="{Binding IsHotkeyEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Margin="0,0,0,6"
                              Foreground="#2F3A4A" />

                    <DockPanel IsEnabled="{Binding IsHotkeyEnabled}"
                               Margin="0,0,0,10">
                        <Button DockPanel.Dock="Right"
                                Width="66"
                                Height="26"
                                Margin="8,0,0,0"
                                Content="{Binding ShowHotkeyCaptureButtonText}"
                                Click="RecordShowHotkeyButton_Click" />
                        <Border BorderBrush="#D5DEE8"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8,5"
                                Background="#F8FAFC">
                            <TextBlock Text="{Binding HotkeyText}"
                                       Style="{StaticResource SettingsLabelStyle}" />
                        </Border>
                    </DockPanel>

                    <CheckBox Content="启用桌面快捷键"
                              IsChecked="{Binding IsDesktopHotkeysEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Margin="0,0,0,6"
                              Foreground="#2F3A4A" />

                    <DockPanel IsEnabled="{Binding IsDesktopHotkeysEnabled}"
                               Margin="0,0,0,12">
                        <ComboBox Width="122"
                                  Margin="0,0,8,0"
                                  ItemsSource="{Binding HotkeyModifierOptions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Value"
                                  SelectedValue="{Binding DesktopHotkeyModifiers, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="数字键，0 为第 10 个桌面，支持两位数字"
                                   Style="{StaticResource SettingsLabelStyle}" />
                    </DockPanel>

                    <TextBlock Text="{Binding HotkeyStatusMessage}"
                               Visibility="{Binding HasHotkeyStatus, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Margin="0,0,0,12"
                               FontSize="12"
                               Foreground="#B45309"
                               TextWrapping="Wrap" />

                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="每行列数"
                                   Style="{StaticResource SettingsLabelStyle}" />
                        <ComboBox DockPanel.Dock="Right"
                                  Width="74"
                                  ItemsSource="{Binding ColumnOptions}"
                                  SelectedItem="{Binding ColumnsPerRow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>

                    <TextBlock Text="{Binding WindowOpacityPercent, StringFormat=透明度 {0}%}"
                               Style="{StaticResource SettingsLabelStyle}"
                               Margin="0,0,0,4" />
                    <Slider Minimum="0.35"
                            Maximum="1"
                            TickFrequency="0.05"
                            SmallChange="0.05"
                            LargeChange="0.1"
                            IsSnapToTickEnabled="False"
                            Value="{Binding WindowOpacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Border>

            <ItemsControl x:Name="DesktopItems"
                          ItemsSource="{Binding Desktops}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <primitives:UniformGrid Columns="{Binding ColumnsPerRow}" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:DesktopButtonViewModel}">
                        <Button Style="{StaticResource DesktopButtonStyle}"
                                Command="{Binding DataContext.SwitchDesktopCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding Id}"
                                Loaded="DesktopButton_Loaded"
                                SizeChanged="DesktopButton_SizeChanged"
                                ToolTip="{Binding DisplayName}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="0" />
                                    <ColumnDefinition Width="2" />
                                    <ColumnDefinition Width="*" MinWidth="0" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="DesktopTitleText"
                                           Grid.Column="0"
                                           Text="{Binding DisplayName}"
                                           FontSize="13"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text=""
                                           FontSize="1"
                                           Width="0"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="DesktopIndexText"
                                           Grid.Column="2"
                                           Text="{Binding Index}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="#64748B"
                                           MinWidth="0"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl x:Name="VirtualDesktopActionItems"
                          Margin="2,2,2,0"
                          ItemsSource="{Binding VirtualDesktopActions}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:VirtualDesktopActionButtonViewModel}">
                        <Button Style="{StaticResource VirtualDesktopActionButtonStyle}"
                                Command="{Binding DataContext.ExecuteVirtualDesktopActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding Action}"
                                ToolTip="{Binding ToolTipText}">
                            <TextBlock Text="{Binding IconGlyph}"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="{Binding StatusMessage}"
                       Visibility="{Binding HasStatus, Converter={StaticResource BooleanToVisibilityConverter}}"
                       Margin="2,2,2,0"
                       MaxWidth="460"
                       FontSize="12"
                       Foreground="#B42318"
                       TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</Window>
