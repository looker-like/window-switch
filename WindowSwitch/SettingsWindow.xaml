<Window x:Class="WindowSwitch.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WindowSwitch 设置"
        Width="420"
        Height="520"
        MinWidth="360"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA"
        ShowInTaskbar="False">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="SectionCardStyle" TargetType="{x:Type Border}">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D8E0EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="HintTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="SettingLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="18">
            <TextBlock Text="WindowSwitch"
                       Foreground="#0F172A"
                       FontSize="20"
                       FontWeight="SemiBold" />
            <TextBlock Text="轻量虚拟桌面工具设置"
                       Margin="0,2,0,16"
                       Style="{StaticResource HintTextStyle}" />

            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel>
                    <TextBlock Text="行为"
                               Style="{StaticResource SectionTitleStyle}" />
                    <CheckBox Content="启动后隐藏到后台"
                              IsChecked="{Binding StartHidden, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Margin="0,0,0,8"
                              Foreground="#2F3A4A" />
                    <CheckBox Content="切换后自动隐藏"
                              IsChecked="{Binding AutoHideAfterSwitch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Foreground="#2F3A4A" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel>
                    <TextBlock Text="唤起快捷键"
                               Style="{StaticResource SectionTitleStyle}" />
                    <CheckBox Content="启用唤起快捷键"
                              IsChecked="{Binding IsHotkeyEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Margin="0,0,0,10"
                              Foreground="#2F3A4A" />
                    <DockPanel IsEnabled="{Binding IsHotkeyEnabled}"
                               Margin="0,0,0,10">
                        <Button DockPanel.Dock="Right"
                                Width="72"
                                Height="28"
                                Margin="8,0,0,0"
                                Content="{Binding ShowHotkeyCaptureButtonText}"
                                Click="RecordShowHotkeyButton_Click" />
                        <Border BorderBrush="#D5DEE8"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="9,6"
                                Background="#F8FAFC">
                            <TextBlock Text="{Binding HotkeyText}"
                                       Style="{StaticResource SettingLabelStyle}" />
                        </Border>
                    </DockPanel>
                    <TextBlock Text="{Binding HotkeyStatusMessage}"
                               Visibility="{Binding HasHotkeyStatus, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Foreground="#B45309"
                               Style="{StaticResource HintTextStyle}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel>
                    <TextBlock Text="桌面快捷键"
                               Style="{StaticResource SectionTitleStyle}" />
                    <CheckBox Content="启用桌面快捷键"
                              IsChecked="{Binding IsDesktopHotkeysEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Margin="0,0,0,10"
                              Foreground="#2F3A4A" />
                    <DockPanel IsEnabled="{Binding IsDesktopHotkeysEnabled}">
                        <ComboBox Width="130"
                                  Margin="0,0,10,0"
                                  ItemsSource="{Binding HotkeyModifierOptions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Value"
                                  SelectedValue="{Binding DesktopHotkeyModifiers, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="数字键，0 为第 10 个桌面，支持两位数字"
                                   Style="{StaticResource HintTextStyle}" />
                    </DockPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel>
                    <TextBlock Text="显示"
                               Style="{StaticResource SectionTitleStyle}" />
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="每行列数"
                                   Style="{StaticResource SettingLabelStyle}" />
                        <ComboBox DockPanel.Dock="Right"
                                  Width="82"
                                  ItemsSource="{Binding ColumnOptions}"
                                  SelectedItem="{Binding ColumnsPerRow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>
                    <TextBlock Text="{Binding WindowOpacityPercent, StringFormat=透明度 {0}%}"
                               Style="{StaticResource SettingLabelStyle}"
                               Margin="0,0,0,6" />
                    <Slider Minimum="0.35"
                            Maximum="1"
                            TickFrequency="0.05"
                            SmallChange="0.05"
                            LargeChange="0.1"
                            Value="{Binding WindowOpacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
