#!/bin/sh
set -eu

if [ "${SKIP_WINDOWSWITCH_HOOK:-}" = "1" ]; then
  echo "WindowSwitch post-commit hook skipped."
  exit 0
fi

if ! git diff-tree --no-commit-id --name-only -r HEAD | grep -Eq '\.cs$'; then
  echo "WindowSwitch post-commit code file length check skipped: no C# files changed."
  exit 0
fi

echo "Running WindowSwitch post-commit code file length check..."
python scripts/check_code_file_length.py --max-lines 300
